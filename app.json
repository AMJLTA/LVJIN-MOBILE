{
  "expo": {
    "name": "绿晋机械臂",
    "slug": "greenjin-mobile",
    "scheme": "greenjin",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "LVJIN ROBOTICS SO101 机械臂的官方配套应用 —— 实时监控关节状态、远程遥控、采集模仿学习数据。",
    "primaryColor": "#7c5cff",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tech.greenjin.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "需要访问本地网络以连接同一 Wi-Fi 下的 SO101 机械臂。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "tech.greenjin.mobile",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA", "android.permission.INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "需要访问相机以录制机械臂演示视频用于训练数据采集。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
